# ── MEXC API credentials ───────────────────────────────────────────────────────
# Generate at: https://www.mexc.com/user/openapi
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# ── Telegram bot ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Comma-separated Telegram user IDs allowed to control the bot
# Find your ID by messaging @userinfobot
ALLOWED_USER_IDS=123456789,987654321

# ── Database (Supabase PostgreSQL via pooler) ──────────────────────────────────
# Dashboard → Settings → Database → Connection string → Transaction pooler
# Use port 6543 (PgBouncer transaction mode) for free-tier connection efficiency.
DATABASE_URL=postgresql://postgres.your-project-ref:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# ── Optional ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
