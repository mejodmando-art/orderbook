# ── MEXC API credentials ───────────────────────────────────────────────────────
# Generate at: https://www.mexc.com/user/openapi
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# ── Telegram bot ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Comma-separated Telegram user IDs allowed to control the bot
# Find your ID by messaging @userinfobot
ALLOWED_USER_IDS=123456789,987654321

# ── Supabase ───────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
# Use the service-role key (not anon) so the bot can bypass Row Level Security
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ── Optional ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
